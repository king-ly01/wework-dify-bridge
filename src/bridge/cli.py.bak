#!/usr/bin/env python3
# encoding:utf-8
"""
Bridge CLI - 企微-Dify 桥接管理工具

用法:
    bridge start              启动服务
    bridge stop               停止服务
    bridge restart            重启服务
    bridge status             查看运行状态
    bridge logs               查看日志
    bridge id                 查看所有机器人列表
    bridge id <id>            查看指定机器人详情
    bridge config             交互式配置新机器人
    bridge gateway            查看网关配置
    bridge gateway port 8899  修改网关端口
"""

import json
import os
import secrets
import sys
import shutil

# 导入 TUI 组件（蓝色主题）
from .tui import (
    interactive_menu, confirm_dialog, input_dialog, info_dialog,
    print_config_result, blue, bright_blue
)

# 导入核心模块
from .core import (
    CONFIG_FILE, PID_FILE, LOG_FILE,
    load_config, save_config,
    is_running, start_service, stop_service,
    validate_bot_id_uniqueness
)

# 导入网络模块
from .network import (
    test_wecom_connection,
    test_dify_connection,
    wait_for_chatid,
    send_welcome_message
)

# 导入工具
from .utils import get_host_ip


class MenuCancelled(Exception):
    """用户取消菜单选择"""
    pass


# ── 命令实现 ──────────────────────────────────────────────────

def cmd_start():
    """启动服务"""
    success, msg = start_service(PID_FILE, LOG_FILE)
    if success:
        print(green(f"✅ {msg}"))
    else:
        print(yellow(f"⚠️  {msg}"))


def cmd_stop():
    """停止服务"""
    success, msg = stop_service(PID_FILE)
    if success:
        print(green(f"✅ {msg}"))
    else:
        print(yellow(f"⚠️  {msg}"))


def cmd_restart():
    """重启服务"""
    running, _ = is_running(PID_FILE)
    if running:
        cmd_stop()
    cmd_start()


def cmd_status():
    """查看服务状态"""
    running, pid = is_running(PID_FILE)
    cfg = load_config()
    port = cfg.get("service", {}).get("notify_port", 8899)
    
    print()
    print(bold("=" * 60))
    print(bold("  服务状态"))
    print(bold("=" * 60))
    print()
    
    if running:
        print(f"  状态:     {green('运行中')}")
        print(f"  PID:      {cyan(str(pid))}")
    else:
        print(f"  状态:     {red('已停止')}")
    
    print(f"  端口:     {cyan(str(port))}")
    print(f"  配置目录: {gray(CONFIG_FILE)}")
    print()
    print(bold("=" * 60))
    print()


def cmd_logs(lines: int = 50, follow: bool = False):
    """查看日志"""
    if not os.path.exists(LOG_FILE):
        print(yellow("日志文件不存在"))
        return
    
    if follow:
        # 实时跟踪日志
        print(gray("按 Ctrl+C 退出日志跟踪"))
        print()
        try:
            import subprocess
            subprocess.run(["tail", "-f", LOG_FILE])
        except KeyboardInterrupt:
            print()
    else:
        # 显示最后 N 行
        try:
            with open(LOG_FILE, 'r') as f:
                all_lines = f.readlines()
                for line in all_lines[-lines:]:
                    print(line, end='')
        except Exception as e:
            print(red(f"读取日志失败: {e}"))


def cmd_id(bot_id: str = None):
    """查看机器人列表或详情"""
    cfg = load_config()
    bots = cfg.get("bots", [])
    
    if bot_id:
        # 查看指定机器人详情
        for bot in bots:
            if bot.get("id") == bot_id:
                print()
                print(bold("=" * 60))
                print(bold(f"  机器人详情: {bot_id}"))
                print(bold("=" * 60))
                print()
                print(f"  ID:          {cyan(bot.get('id', 'N/A'))}")
                print(f"  配置人:      {cyan(bot.get('owner', 'N/A'))}")
                print(f"  功能描述:    {bot.get('description', 'N/A')}")
                print(f"  Token:       {gray(bot.get('token', 'N/A')[:20])}...")
                print()
                print(f"  企业微信 Bot ID: {cyan(bot.get('wecom', {}).get('bot_id', 'N/A'))}")
                print()
                print(f"  Dify API Base: {cyan(bot.get('dify', {}).get('api_base', 'N/A'))}")
                print()
                print(bold("=" * 60))
                print()
                return
        print(red(f"找不到机器人: {bot_id}"))
    else:
        # 列出所有机器人
        print()
        print(bold("=" * 60))
        print(bold("  机器人列表"))
        print(bold("=" * 60))
        print()
        
        if not bots:
            print(gray("  暂无配置的机器人"))
        else:
            print(f"  {'ID':<20} {'配置人':<12} {'功能描述'}")
            print("  " + "-" * 56)
            for bot in bots:
                bid = bot.get('id', 'N/A')[:18]
                owner = bot.get('owner', 'N/A')[:10]
                desc = bot.get('description', 'N/A')[:20]
                print(f"  {cyan(bid):<20} {owner:<12} {gray(desc)}")
        
        print()
        print(gray("  查看详情: bridge id <机器人ID>"))
        print(bold("=" * 60))
        print()


def cmd_config():
    """交互式机器人配置管理（TUI 版本）"""
    while True:
        try:
            cfg = load_config()
            bot_count = len(cfg.get("bots", []))
            
            choice = interactive_menu(
                f"机器人管理  (当前: {bot_count}个)",
                [
                    ("1", "新增机器人连接"),
                    ("2", "修改机器人连接"),
                    ("3", "查询机器人连接"),
                    ("4", "删除机器人连接"),
                ]
            )
            
            if choice is None:
                break
            elif choice == "1":
                create_robot_tui()
            elif choice == "2":
                modify_robot_tui()
            elif choice == "3":
                query_robots_tui()
            elif choice == "4":
                delete_robot_tui()
        
        except KeyboardInterrupt:
            print()
            print(blue("  已退出"))
            print()
            break
        except Exception as e:
            print()
            print(blue(f"  错误: {e}"))
            print()
            input(blue("  按回车键继续..."))


def create_robot_tui():
    """TUI 版本创建机器人"""
    cfg = load_config()
    
    try:
        # 1. 配置人信息
        owner = input_dialog("请输入您的姓名")
        if not owner:
            return
        
        # 2. 机器人 ID
        while True:
            bot_id = input_dialog("请输入机器人 ID")
            if not bot_id:
                return
            valid, msg = validate_bot_id_uniqueness(cfg.get("bots", []), owner, bot_id)
            if valid:
                break
            info_dialog(f"错误: {msg}")
        
        # 3. 描述
        description = input_dialog("请输入机器人用途描述")
        
        # 4. 企微配置
        wecom_bot_id = input_dialog("请输入企业微信 Bot ID")
        if not wecom_bot_id:
            return
        
        wecom_secret = input_dialog("请输入企业微信 Secret")
        if not wecom_secret:
            return
        
        # 测试连接
        info_dialog("正在测试企业微信连接...")
        success, msg = test_wecom_connection(wecom_bot_id, wecom_secret)
        if not success:
            if not confirm_dialog(f"连接失败: {msg}\n是否继续配置?"):
                return
        
        # 5. 获取 chatid
        info_dialog("请在企业微信中给机器人发送一条消息\n(例如: '你好' 或 '开始配置')\n\n等待消息中...")
        success, result = wait_for_chatid(wecom_bot_id, wecom_secret, timeout=60)
        
        if success:
            chatid = result
            info_dialog(f"已收到消息！获取到 Chat ID\n发送欢迎消息中...")
            send_welcome_message(wecom_bot_id, wecom_secret, chatid, owner, bot_id)
        else:
            chatid = ""
            info_dialog(f"未收到消息: {result}\n您可以稍后在配置文件中手动添加 chatid")
        
        # 6. Dify 配置
        dify_api_base = input_dialog("请输入 Dify API Base URL", default="http://127.0.0.1/v1")
        dify_api_key = input_dialog("请输入 Dify API Key (app-xxx)")
        
        if dify_api_key:
            info_dialog("正在测试 Dify 连接...")
            success, msg = test_dify_connection(dify_api_base, dify_api_key)
            if not success:
                if not confirm_dialog(f"连接失败: {msg}\n是否继续配置?"):
                    return
        
        # 7. 保存配置
        token = secrets.token_hex(20)
        
        bot_entry = {
            "id": bot_id,
            "owner": owner,
            "description": description,
            "token": token,
            "wecom": {
                "bot_id": wecom_bot_id,
                "secret": wecom_secret
            },
            "dify": {
                "api_base": dify_api_base,
                "api_key": dify_api_key,
                "input_variable": "input",
                "output_variable": "text",
                "timeout": 60
            },
            "default_chatid": chatid,
            "welcome_message": f"你好！我是{description}，有什么可以帮你的吗？",
            "thinking_message": "⏳ 思考中..."
        }
        
        cfg["bots"].append(bot_entry)
        save_config(cfg)
        
        # 8. 显示结果
        port = cfg.get("service", {}).get("notify_port", 8899)
        host_ip = get_host_ip()
        
        docker_url = f"http://host.docker.internal:{port}/notify?token={token}"
        host_url = f"http://{host_ip}:{port}/notify?token={token}"
        
        print_config_result(bot_id, owner, description, docker_url, host_url, port)
    
    except KeyboardInterrupt:
        raise


def query_robots_tui():
                print()
                print(gray("  可能原因:"))
                print(gray("    - Bot ID 或 Secret 输入错误"))
                print(gray("    - 网络无法连接到企业微信服务器"))
                print(gray("    - 机器人未在企业微信后台启用"))
                print()
